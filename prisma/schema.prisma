generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           String   @default("operador") // Pode ser "gerente" ou "operador"
  isTempPassword Boolean  @default(false)      // Controle da senha temporária
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String   @unique
  category    String
  quantity    Int
  minQuantity Int
  price       Float
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}