# Configurações do Servidor
PORT=3000

# URL de conexão com o banco de dados MySQL
# O Prisma usa DATABASE_URL para conectar — escolha uma das opções abaixo:

# Opção 1 — MySQL Workbench (banco local)
# DATABASE_URL="mysql://root:sua_senha@localhost:3306/boistockdb"

# Opção 2 — Docker (container MySQL)
# DATABASE_URL="mysql://root:sua_senha@localhost:3306/boistockdb"
# Se o app também rodar dentro do Docker, substitua "localhost" pelo nome do serviço:
# DATABASE_URL="mysql://root:sua_senha@mysql:3306/boistockdb"

DATABASE_URL=
